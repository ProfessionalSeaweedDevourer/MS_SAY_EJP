# Copy to `.env` and fill values used by `pivot_back/database.py`
# Required keys used by the app:
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=192.168.0.10
DB_PORT=1521
DB_SERVICE=ORCLCDB

# Notes:
# - `DB_HOST` can be a LAN IP or hostname reachable from the developer machine.
# - `DB_SERVICE` is the Oracle SERVICE_NAME (not SID) as used in the connection string.
# - After populating `.env`, run the backend with:
#   python -m uvicorn main:app --reload --port 8000
